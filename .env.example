# ----------------------------------------------------------------------------
# Linearr — environment configuration
# Copy this file to `.env` and edit. All other values have sensible defaults.
#
# Configure Plex, Jellyfin, or both. At least one is required. With both
# configured, every new playlist gets a "Push to: Both / Plex / Jellyfin"
# picker; with only one, the picker is hidden and that backend is used.
# ----------------------------------------------------------------------------

# Plex --------------------------------------------------------------------- #
# Set these to enable Plex. Use the LAN IP of your Plex server, not plex.tv.
# Get the token from https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your-x-plex-token-here

# Jellyfin ---------------------------------------------------------------- #
# Set these to enable Jellyfin. USERNAME + PASSWORD (not an API key) — the
# Jellyfin playlist endpoints we need are broken with API-key auth, so we
# authenticate as a user via POST /Users/AuthenticateByName instead.
# The access token is held in memory only and never written to disk.
# Leave commented out (or blank) to run Plex-only.
# JELLYFIN_URL=http://192.168.1.100:8096
# JELLYFIN_USERNAME=your-jellyfin-username
# JELLYFIN_PASSWORD=your-jellyfin-password

# Web UI -----------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=5005

# Pruning ---------------------------------------------------------------------
# Keep this many recently-watched episodes in each playlist as a fall-asleep
# buffer; older watched episodes are removed on each prune sweep.
WATCHED_KEEP=2

# How often the background prune sweep runs (minutes). Auto-sync (below)
# runs on the same interval.
PRUNE_INTERVAL_MINUTES=10

# How often franchise definitions are refreshed from upstream sources (days).
# Default 7 (weekly). Set to 30 for ~monthly. Chronolists sources are cheap
# (a single index request per refresh, full download only when a list changed).
FRANCHISE_REFRESH_DAYS=7

# Auto-sync ------------------------------------------------------------------
# When true (default), every PRUNE_INTERVAL_MINUTES the app re-checks each
# managed playlist against current Plex metadata. Newly-aired episodes and
# new seasons (within each show's configured range) are spliced into the
# future portion of the playlist; episodes deleted from Plex drop out.
# Set to false to lock playlists at creation time — they'll only update when
# you manually edit them.
AUTO_SYNC=true

# Storage ---------------------------------------------------------------------
# SQLite DB path. Defaults to ./data for bare-metal Python runs.
# Docker (compose & Unraid template) overrides this to /data/rotator.db.
DB_PATH=./data/rotator.db

# Optional --------------------------------------------------------------------
# Comma-separated TV library names to source shows from. Leave blank to use
# every "show" library on the server.
TV_LIBRARIES=

# Random secret for Flask session cookies. Generate with: openssl rand -hex 32
# Leave blank to use the (insecure) built-in dev secret.
FLASK_SECRET=
