# ----------------------------------------------------------------------------
# Plex Rotator — environment configuration
# Copy this file to `.env` and edit. All other values have sensible defaults.
# ----------------------------------------------------------------------------

# Plex server connection (REQUIRED)
# Use the LAN IP of your Plex server, not plex.tv.
PLEX_URL=http://192.168.1.100:32400

# X-Plex-Token — see README for how to get one.
PLEX_TOKEN=your-x-plex-token-here

# Web UI -----------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=5005

# Pruning ---------------------------------------------------------------------
# Keep this many recently-watched episodes in each playlist as a fall-asleep
# buffer; older watched episodes are removed on each prune sweep.
WATCHED_KEEP=2

# How often the background prune sweep runs (minutes).
PRUNE_INTERVAL_MINUTES=10

# Storage ---------------------------------------------------------------------
# SQLite DB path. Defaults to ./data for bare-metal Python runs.
# Docker (compose & Unraid template) overrides this to /data/rotator.db.
DB_PATH=./data/rotator.db

# Optional --------------------------------------------------------------------
# Comma-separated TV library names to source shows from. Leave blank to use
# every "show" library on the server.
TV_LIBRARIES=

# Random secret for Flask session cookies. Generate with: openssl rand -hex 32
# Leave blank to use the (insecure) built-in dev secret.
FLASK_SECRET=
